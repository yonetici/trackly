msgstr "Kaydedilen Tıklamalar:"

msgid "GA4 Event Builder"
msgstr "GA4 Olay Oluşturucu"

msgid ""
"Create custom GA4 tracking events by selecting buttons or links on the page."
msgstr "Sayfadaki düğmeleri veya bağlantıları seçerek özel GA4 izleme olayları oluşturun."

msgid "Start Element Selection"
msgstr "Öğe Seçimini Başlat"

msgid ""
"Click the button, then hover over any button/link you wish to track on the "
"page."
msgstr "Düğmeye tıklayın, ardından sayfada izlemek istediğiniz herhangi bir düğmenin/bağlantının üzerine gelin."

msgid "Selected Element:"
msgstr "Seçilen Öğe:"

msgid "GA4 Event Name:"
msgstr "GA4 Olay Adı:"

msgid "e.g., cta_button_click"
msgstr "örn. cta_button_click"

msgid "Save"
msgstr "Kaydet"

msgid "Cancel"
msgstr "İptal"

msgid "Predictive Page Analysis"
msgstr "Öngörüsel Sayfa Analizi"

msgid "Content Performance"
msgstr "İçerik Performansı"

msgid "Predictive anomaly engine is calculating statistics..."
msgstr "Öngörüsel anomali motoru istatistikleri hesaplıyor..."

msgid "Go to Dashboard"
msgstr "Panoya Git"

msgid "Once Weekly"
msgstr "Haftada Bir"

msgid "Invalid JSON format."
msgstr "Geçersiz JSON biçimi."

msgid "No data found."
msgstr "Veri bulunamadı."

msgid "Loading..."
msgstr "Yükleniyor..."

